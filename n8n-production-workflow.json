        "message": "=<html><body style=\"font-family:-apple-system,sans-serif;max-width:600px;margin:0 auto;padding:24px\">\n<h2 style=\"color:#16a34a\">Article Published!</h2>\n<p><strong>Title:</strong> {{ $('Format Article').first().json.title }}</p>\n<p><strong>Live URL:</strong> <a href=\"{{ $json.link }}\">{{ $json.link }}</a></p>\n<p style=\"color:#6b7280;font-size:13px\">Published via your AI content pipeline.</p>\n</body></html>",
        "options": {}
